{
  "name": "kansodb",
  "version": "0.15.0",
  "description": "A small SQL query engine built from scratch in TypeScript.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run typecheck && npm run frontend:typecheck",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "frontend": "vite --config frontend/vite.config.ts --host 127.0.0.1",
    "frontend:typecheck": "tsc -p frontend/tsconfig.json --noEmit",
    "frontend:build": "vite build --config frontend/vite.config.ts",
    "frontend:preview": "vite preview --config frontend/vite.config.ts --host 127.0.0.1"
  },
  "keywords": [
    "sql",
    "database",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  }
}
